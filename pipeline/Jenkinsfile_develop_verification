pipeline {
    agent any

    stages {
        stage('Checkout') {
            steps {
                checkout scmGit(
                    branches: [[name: '*/main']],
                    userRemoteConfigs: [[
                        url: 'https://github.com/sangdoedu/python_fastapi_ai_analytics.git',
                        credentialsId: 'token_w_github' 
                    ]]
                )
            }
        }
        
        stage('Debug Files') {
          steps {
            sh 'pwd'
            sh 'ls -la'
          }
        }

        stage('Install Dependencies') {
            agent {
                docker { 
                    image 'python:3.9-slim' 
                    // This tells Jenkins to run this stage INSIDE a Python container
                    // Force the container to run as root to avoid the 'site-packages' error
                    args '-u root'
                }
            }
            
            steps {
                // This writes a NEW file inside the Python container's current folder
                // using the contents of the file Jenkins can see.
                sh "echo \"\$(cat requirements.txt)\" > local_requirements.txt"
                sh "pip install --no-cache-dir -r local_requirements.txt"
            }
        }

        stage('Run Tests') {
            steps {
                sh '''
                pytest tests/
                '''
            }
        }
    }
    
    post {
        always {
            echo 'Cleaning up workspace...'
        }
        success {
            echo 'CI Pipeline Passed!'
        }
        failure {
            echo 'CI Pipeline Failed. Check logs.'
        }
    }
}