pipeline {
    agent any

    stages {
        stage('Checkout') {
            steps {
                checkout scmGit(
                    branches: [[name: '*/main']],
                    userRemoteConfigs: [[
                        url: 'https://github.com/sangdoedu/python_fastapi_ai_analytics.git',
                        credentialsId: 'token_w_github' 
                    ]]
                )
            }
        }
        
        stage('Debug Files') {
          steps {
            sh 'pwd'
            sh 'ls -la'
          }
        }
        
        stage('Install and Test') {
            steps {
                withCredentials([string(credentialsId: 'GROQ_API_KEY', variable: 'GROQ_API_KEY')]) {
                    sh '''
                    docker run --rm \
                      --volumes-from jenkins-server \
                      -w "${WORKSPACE}" \
                      -e GROQ_API_KEY="${GROQ_API_KEY}" \
                      python:3.9-slim \
                      bash -c "pip install --no-cache-dir -r requirements.txt && export PYTHONPATH=$PYTHONPATH:. && python3 -m pytest tests/"
                    '''
                }
            }
        }

        
    }
    
    post {
        always {
            echo 'Cleaning up workspace...'
        }
        success {
            echo 'CI Pipeline Passed!'
        }
        failure {
            echo 'CI Pipeline Failed. Check logs.'
        }
    }
}