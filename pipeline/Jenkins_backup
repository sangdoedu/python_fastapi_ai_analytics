pipeline {
    agent any

    stages {
        stage('Backup MongoDB') {
            steps {
                withCredentials([string(credentialsId: 'mongo-uri', variable: 'MONGO_URI')]) {
                    sh '''
                    BACKUP_DIR=/Users/sangdo/Documents/Backup/backup_$(date +%Y%m%d_%H%M%S)
                    mkdir -p $BACKUP_DIR

                    /opt/homebrew/bin/mongodump --uri="$MONGO_URI" --db fastapi_finance --out=$BACKUP_DIR

                    tar -czf $BACKUP_DIR.tar.gz $BACKUP_DIR
                    rm -rf $BACKUP_DIR

                    echo "Backup created: $BACKUP_DIR.tar.gz"
                    '''
                }
            }
        }
    }
}